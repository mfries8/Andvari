# =========================
# Andvari Specific ignores
# =========================

# Ignore all drone imagery, training tiles, and output artifacts. 
# NEVER commit the data folder.
data/

# Ignore the heavy PyTorch weight files. 
# (The folder itself will be tracked if you put a .gitkeep in it, but the weights won't)
models/*.pth

# Ignore temporary UI templates generated by the Auditor
template.html

# Fallback: Ignore any stray GIS or data files that escape the data folder
*.csv
*.kml
*.geojson

